# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://albion:changeme@localhost:5432/albion_tool"
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://:changeme@localhost:6379"
REDIS_PASSWORD=changeme

# ── Nuxt ──────────────────────────────────────────────────────
# Générer via : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_SESSION_SECRET=changeme_32_bytes_hex_secret_here

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Email (pour mot de passe oublié) ─────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@albion-tool.com

# ── First admin (seed) ────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@albion-tool.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme_admin
