// En Prisma 7, la DATABASE_URL est configurée dans prisma.config.ts
// et passée via adaptateur au PrismaClient — pas dans le datasource.

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["queryCompiler", "driverAdapters"]
}

// ══════════════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════════════

enum UserRole {
  ADMIN
  MODERATOR
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum ItemType {
  WEAPON
  OFF_HAND
  ARMOR_HEAD
  ARMOR_CHEST
  ARMOR_SHOES
  BAG
  CAPE
  MOUNT
  CONSUMABLE
  RESOURCE_RAW
  RESOURCE_REFINED
  PRODUCT
  FARMABLE
  FURNITURE
  JOURNAL
  LABORER
  OTHER
}

enum LocationType {
  ROYAL_CITY
  BLACK_ZONE_CITY
  OUTLAND_CITY
  PORTAL_CITY
  OTHER
}

enum ImportType {
  FULL
  PARTIAL_ITEMS
  PARTIAL_RECIPES
  ICONS_SYNC
  REINDEX
}

enum ImportStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  PARTIAL_SUCCESS
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// ══════════════════════════════════════════════════════════════
// USERS & AUTH
// ══════════════════════════════════════════════════════════════

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  username             String     @unique
  passwordHash         String
  role                 UserRole   @default(USER)
  status               UserStatus @default(PENDING_VERIFICATION)

  emailVerified        Boolean    @default(false)
  emailVerifyToken     String?    @unique
  emailVerifyExpires   DateTime?

  resetPasswordToken   String?    @unique
  resetPasswordExpires DateTime?

  lastLoginAt          DateTime?
  lastLoginIp          String?

  sessions             Session[]
  auditLogs            AuditLog[]
  importJobs           ImportJob[]

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ══════════════════════════════════════════════════════════════
// TAXONOMY
// ══════════════════════════════════════════════════════════════

model Category {
  id        String     @id
  slug      String     @unique
  nameEn    String
  sortOrder Int        @default(0)

  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  items     Item[]

  @@index([parentId])
}

// ══════════════════════════════════════════════════════════════
// ITEMS
// ══════════════════════════════════════════════════════════════

model Item {
  id               String   @id
  uniqueName       String   @unique
  tier             Int
  enchantmentLevel Int      @default(0)

  shopCategory     String?
  shopSubcategory  String?
  shopSubcategory2 String?
  itemType         ItemType @default(OTHER)
  categoryId       String?

  weight           Float?
  maxStackSize     Int?
  canBeOvercharged Boolean  @default(false)
  isCraftable      Boolean  @default(false)
  isRefinable      Boolean  @default(false)

  stats       Json?
  craftSpells Json?

  iconUrl       String?
  iconLocalPath String?
  iconFetched   Boolean  @default(false)
  iconFetchedAt DateTime?

  baseItemId      String?
  baseItem        Item?    @relation("EnchantVariants", fields: [baseItemId], references: [id])
  enchantVariants Item[]   @relation("EnchantVariants")

  category       Category?            @relation(fields: [categoryId], references: [id])
  localizations  ItemLocalization[]
  craftingRecipe CraftingRecipe?      @relation("CraftedItem")
  refiningRecipe RefiningRecipe?      @relation("RefinedItem")

  usedInCrafting CraftingIngredient[]
  usedInRefining RefiningIngredient[]
  cityBonuses    CityItemBonus[]

  dataHash   String?
  importedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tier])
  @@index([enchantmentLevel])
  @@index([tier, enchantmentLevel])
  @@index([categoryId])
  @@index([itemType])
  @@index([shopCategory])
  @@index([shopSubcategory2])
  @@index([baseItemId])
  @@index([isCraftable])
  @@index([isRefinable])
  @@index([iconFetched])
}

model ItemLocalization {
  id          String  @id @default(cuid())
  itemId      String
  locale      String
  name        String
  description String? @db.Text

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, locale])
  @@index([itemId])
  @@index([locale])
  @@index([name])
}

// ══════════════════════════════════════════════════════════════
// CRAFTING & REFINING
// ══════════════════════════════════════════════════════════════

model CraftingStation {
  id       String @id
  name     String
  type     String
  maxLevel Int    @default(3)

  craftingRecipes CraftingRecipe[]
  refiningRecipes RefiningRecipe[]

  @@index([type])
}

model CraftingRecipe {
  id                String  @id @default(cuid())
  resultItemId      String  @unique
  craftingStationId String?
  resultCount       Int     @default(1)
  craftingFame      Float   @default(0)
  silverCost        Float   @default(0)
  canBeOvercharged  Boolean @default(false)
  focusable         Boolean @default(true)

  ingredients     CraftingIngredient[]
  resultItem      Item             @relation("CraftedItem", fields: [resultItemId], references: [id])
  craftingStation CraftingStation? @relation(fields: [craftingStationId], references: [id])

  @@index([craftingStationId])
}

model CraftingIngredient {
  id            String @id @default(cuid())
  recipeId      String
  itemId        String
  quantity      Int
  maxReturnRate Float?

  recipe CraftingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item           @relation(fields: [itemId], references: [id])

  @@index([recipeId])
  @@index([itemId])
}

model RefiningRecipe {
  id                String  @id @default(cuid())
  resultItemId      String  @unique
  craftingStationId String?
  resultCount       Int     @default(1)

  ingredients     RefiningIngredient[]
  resultItem      Item             @relation("RefinedItem", fields: [resultItemId], references: [id])
  craftingStation CraftingStation? @relation(fields: [craftingStationId], references: [id])

  @@index([craftingStationId])
}

model RefiningIngredient {
  id            String @id @default(cuid())
  recipeId      String
  itemId        String
  quantity      Int
  maxReturnRate Float?

  recipe RefiningRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item           @relation(fields: [itemId], references: [id])

  @@index([recipeId])
  @@index([itemId])
}

// ══════════════════════════════════════════════════════════════
// LOCATIONS & CITY BONUSES
// ══════════════════════════════════════════════════════════════

model Location {
  id       String       @id
  name     String
  type     LocationType
  isActive Boolean      @default(true)

  cityBonuses CityItemBonus[]

  @@index([type])
}

model CityItemBonus {
  id            String @id @default(cuid())
  locationId    String
  itemId        String
  craftingBonus Float  @default(0)
  refiningBonus Float  @default(0)

  location Location @relation(fields: [locationId], references: [id])
  item     Item     @relation(fields: [itemId], references: [id])

  @@unique([locationId, itemId])
  @@index([locationId])
  @@index([itemId])
}

model ReturnRate {
  id               String @id @default(cuid())
  tier             Int
  enchantmentLevel Int    @default(0)
  baseReturnRate   Float
  focusReturnRate  Float
  cityBonusRate    Float  @default(0)

  @@unique([tier, enchantmentLevel])
  @@index([tier])
}

// ══════════════════════════════════════════════════════════════
// IMPORT / ADMIN
// ══════════════════════════════════════════════════════════════

model ImportJob {
  id            String       @id @default(cuid())
  type          ImportType
  status        ImportStatus @default(PENDING)

  triggeredById String?
  triggeredBy   User?        @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?

  itemsProcessed Int @default(0)
  itemsCreated   Int @default(0)
  itemsUpdated   Int @default(0)
  itemsSkipped   Int @default(0)
  itemsFailed    Int @default(0)

  sourceCommit String?
  sourceUrl    String?

  errorMessage String?   @db.Text
  logs         ImportLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([triggeredById])
}

model ImportLog {
  id      String   @id @default(cuid())
  jobId   String
  level   LogLevel @default(INFO)
  message String   @db.Text
  context Json?

  job ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([level])
  @@index([createdAt])
}

model AuditLog {
  id         String  @id @default(cuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     String
  targetType String?
  targetId   String?

  before    Json?
  after     Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════
// SYSTEM CONFIG
// ══════════════════════════════════════════════════════════════

model SystemConfig {
  key         String  @id
  value       Json
  description String?

  updatedAt   DateTime @updatedAt
  updatedById String?
}
