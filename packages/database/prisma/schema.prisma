// En Prisma 7, la DATABASE_URL est configurée dans prisma.config.ts
// et passée via adaptateur au PrismaClient — pas dans le datasource.

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["queryCompiler", "driverAdapters"]
}

// ══════════════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════════════

enum UserRole {
  ADMIN
  MODERATOR
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum ItemType {
  WEAPON
  OFF_HAND
  ARMOR_HEAD
  ARMOR_CHEST
  ARMOR_SHOES
  BAG
  CAPE
  MOUNT
  CONSUMABLE
  RESOURCE_RAW
  RESOURCE_REFINED
  PRODUCT
  FARMABLE
  FURNITURE
  JOURNAL
  LABORER
  OTHER
}

enum LocationType {
  ROYAL_CITY
  BLACK_ZONE_CITY
  OUTLAND_CITY
  PORTAL_CITY
  OTHER
}

enum ImportType {
  FULL
  PARTIAL_ITEMS
  PARTIAL_RECIPES
  PARTIAL_SPELLS
  ICONS_SYNC
  REINDEX
}

enum BuildVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum BuildContentType {
  OPEN_WORLD
  MISTS_SOLO
  MISTS_DUO
  CORRUPTED_DUNGEON
  HELLGATE_2V2
  HELLGATE_5V5
  SMALL_SCALE
  ZVZ
  CRYSTAL_ARENA_1V1
  CRYSTAL_ARENA_5V5
  TRACKING_SOLO
  TRACKING_GROUP
  FAME_FARM_SOLO
  FAME_FARM_GROUP
  FAME_FARM_GROUP_AVALON
  GANK_SOLO
  GANK_GROUP
  ABYSSAL_DEPTHS_2V2
  ABYSSAL_DEPTHS_3V3
  GATHERING
  HCE
  ROADS
}

enum BuildRole {
  DPS
  BURST_DPS
  HEALER
  TANK
  SUPPORT
  DISRUPTOR
  MOBILITY
  ECONOMY
}

enum BuildGroupScale {
  SOLO
  DUO
  SMALL_GROUP
  PARTY
  RAID
  MASSIVE
}

enum BuildPlaystyle {
  SAFE_PVE
  PVE_PVP
  ONE_SHOT
  KITE
  BRAWL
  DIVE
  SUSTAIN
  ESCAPE
  CATCH
}

enum BuildDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum BuildBudget {
  LOW
  MEDIUM
  HIGH
  LUXURY
}

enum ImportStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  PARTIAL_SUCCESS
}

enum MarketSyncType {
  FULL
  BATCH
  PRIORITY
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum IslandType {
  PERSONAL
  GUILD
}

enum PlotType {
  FARM
  HERB_GARDEN
  PASTURE
  KENNEL
  HOUSE
  REFINING
  CRAFTING
  BUILDING
}

// ══════════════════════════════════════════════════════════════
// USERS & AUTH
// ══════════════════════════════════════════════════════════════

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  username             String     @unique
  passwordHash         String
  role                 UserRole   @default(USER)
  status               UserStatus @default(PENDING_VERIFICATION)
  avatar               String?

  emailVerified        Boolean    @default(false)
  emailVerifyToken     String?    @unique
  emailVerifyExpires   DateTime?

  resetPasswordToken   String?    @unique
  resetPasswordExpires DateTime?

  lastLoginAt          DateTime?
  lastLoginIp          String?

  sessions             Session[]
  auditLogs            AuditLog[]
  importJobs           ImportJob[]
  marketSyncJobs       MarketSyncJob[]
  builds               Build[]
  buildCollections     BuildCollection[]
  islands              Island[]

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ══════════════════════════════════════════════════════════════
// TAXONOMY
// ══════════════════════════════════════════════════════════════

model Category {
  id        String     @id
  slug      String     @unique
  nameEn    String
  sortOrder Int        @default(0)

  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  items         Item[]
  localizations CategoryLocalization[]

  @@index([parentId])
}

model CategoryLocalization {
  id         String @id @default(cuid())
  categoryId String
  locale     String
  name       String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

// ══════════════════════════════════════════════════════════════
// ITEMS
// ══════════════════════════════════════════════════════════════

model Item {
  id               String   @id
  uniqueName       String   @unique
  tier             Int
  enchantmentLevel Int      @default(0)

  shopCategory     String?
  shopSubcategory  String?
  shopSubcategory2 String?
  itemType         ItemType @default(OTHER)
  categoryId       String?

  weight           Float?
  maxStackSize     Int?
  canBeOvercharged Boolean  @default(false)
  isCraftable      Boolean  @default(false)
  isRefinable      Boolean  @default(false)

  stats       Json?
  craftSpells Json?

  iconUrl       String?
  iconLocalPath String?
  iconFetched   Boolean  @default(false)
  iconFetchedAt DateTime?

  baseItemId      String?
  baseItem        Item?    @relation("EnchantVariants", fields: [baseItemId], references: [id])
  enchantVariants Item[]   @relation("EnchantVariants")

  category       Category?            @relation(fields: [categoryId], references: [id])
  localizations  ItemLocalization[]
  craftingRecipe CraftingRecipe?      @relation("CraftedItem")
  refiningRecipe RefiningRecipe?      @relation("RefinedItem")

  usedInCrafting CraftingIngredient[]
  usedInRefining RefiningIngredient[]
  cityBonuses    CityItemBonus[]
  marketPrices   MarketPrice[]
  marketPricesHistory MarketPriceHistory[]
  resolvedPrices ResolvedPrice[]
  itemSpells     ItemSpell[]
  buildingResources BuildingResource[]
  
  // Farming metadata
  growTime            Int?    // Growth time in seconds
  harvestLootList     String? // Loot list ID for harvest
  harvestLootTable    LootTable? @relation("HarvestLootList", fields: [harvestLootList], references: [id])
  harvestSeedChance   Float?  // Chance to get seed back
  grownItemUniqueName String? // Unique name of the grown animal
  offspringChance     Float?  // Chance to get offspring
  productLootList     String? // Loot list ID for products (eggs, milk)
  productLootTable    LootTable? @relation("ProductLootList", fields: [productLootList], references: [id])
  productProductionTime Int?   // Time to produce (seconds)

  harvestResultItemId String?
  harvestResultItem   Item?    @relation("HarvestResult", fields: [harvestResultItemId], references: [id])
  harvestResultFor    Item[]   @relation("HarvestResult")

  productResultItemId String?
  productResultItem   Item?    @relation("ProductResult", fields: [productResultItemId], references: [id])
  productResultFor    Item[]   @relation("ProductResult")
  favoriteFoodItemId  String? // Item ID of favorite food
  nutritionMax        Float?  // Max nutrition for animals
  
  favoriteFoodFor      CraftingStation[]     @relation("FavoriteDish")
  permittedInStations  StationItem[]
  buildingRequirements BuildingRequirement[]
  lootTableItems       LootTableItem[]


  maxQuality      Int      @default(1)

  dataHash   String?
  importedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tier])
  @@index([enchantmentLevel])
  @@index([tier, enchantmentLevel])
  @@index([categoryId])
  @@index([itemType])
  @@index([shopCategory])
  @@index([shopSubcategory2])
  @@index([baseItemId])
  @@index([isCraftable])
  @@index([isRefinable])
  @@index([iconFetched])
}

model ItemLocalization {
  id          String  @id @default(cuid())
  itemId      String
  locale      String
  name        String
  description String? @db.Text

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, locale])
  @@index([itemId])
  @@index([locale])
  @@index([name])
}

// ══════════════════════════════════════════════════════════════
// CRAFTING & REFINING
// ══════════════════════════════════════════════════════════════

model CraftingStation {
  id                String  @id // Unique name (ex: T4_WEAVINGMILL)
  name              String
  type              String  // Category (ex: craftbuilding, farmbuilding)
  tier              Int     @default(1)
  description       String? @db.Text
  capability        String? @db.Text
  iconUrl           String?
  nutritionStorage  Float?
  
  favoriteDishItemId String?
  favoriteDishBonus  Float?
  
  uiSpriteName       String?
  uiBuildMenuTexture String?

  permittedItems    StationItem[]
  
  nextTierBuildingId String?
  
  nextTierBuilding   CraftingStation?    @relation("BuildingEvolution", fields: [nextTierBuildingId], references: [id])
  previousTierBuildings CraftingStation[] @relation("BuildingEvolution")
  
  requirements       BuildingRequirement[]
  craftingRecipes    CraftingRecipe[]
  refiningRecipes    RefiningRecipe[]
  buildings         IslandBuilding[]
  
  favoriteDish      Item? @relation("FavoriteDish", fields: [favoriteDishItemId], references: [id])

  @@index([type])
  @@index([favoriteDishItemId])
}

model StationItem {
  stationId String
  itemId    String
  station   CraftingStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  item      Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([stationId, itemId])
  @@index([stationId])
  @@index([itemId])
}

model BuildingRequirement {
  id         String @id @default(cuid())
  buildingId String
  itemId     String
  count      Int
  
  building   CraftingStation @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  @@unique([buildingId, itemId])
  @@index([buildingId])
  @@index([itemId])
}

model CraftingRecipe {
  id                String  @id @default(cuid())
  resultItemId      String  @unique
  craftingStationId String?
  resultCount       Int     @default(1)
  craftingFame      Float   @default(0)
  silverCost        Float   @default(0)
  canBeOvercharged  Boolean @default(false)
  focusable         Boolean @default(true)

  ingredients     CraftingIngredient[]
  resultItem      Item             @relation("CraftedItem", fields: [resultItemId], references: [id])
  craftingStation CraftingStation? @relation(fields: [craftingStationId], references: [id])

  @@index([craftingStationId])
}

model CraftingIngredient {
  id            String @id @default(cuid())
  recipeId      String
  itemId        String
  quantity      Int
  maxReturnRate Float?

  recipe CraftingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item           @relation(fields: [itemId], references: [id])

  @@index([recipeId])
  @@index([itemId])
}

model RefiningRecipe {
  id                String  @id @default(cuid())
  resultItemId      String  @unique
  craftingStationId String?
  resultCount       Int     @default(1)

  ingredients     RefiningIngredient[]
  resultItem      Item             @relation("RefinedItem", fields: [resultItemId], references: [id])
  craftingStation CraftingStation? @relation(fields: [craftingStationId], references: [id])

  @@index([craftingStationId])
}

model RefiningIngredient {
  id            String @id @default(cuid())
  recipeId      String
  itemId        String
  quantity      Int
  maxReturnRate Float?

  recipe RefiningRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item           @relation(fields: [itemId], references: [id])

  @@index([recipeId])
  @@index([itemId])
}

// ══════════════════════════════════════════════════════════════
// LOCATIONS & CITY BONUSES
// ══════════════════════════════════════════════════════════════

model Location {
  id       String       @id
  name     String
  type     LocationType
  isActive Boolean      @default(true)

  cityBonuses    CityItemBonus[]
  marketPrices   MarketPrice[]
  resolvedPrices ResolvedPrice[]
  islands        Island[]

  @@index([type])
}

model CityItemBonus {
  id            String @id @default(cuid())
  locationId    String
  itemId        String
  craftingBonus Float  @default(0)
  refiningBonus Float  @default(0)

  location Location @relation(fields: [locationId], references: [id])
  item     Item     @relation(fields: [itemId], references: [id])

  @@unique([locationId, itemId])
  @@index([locationId])
  @@index([itemId])
}

model ReturnRate {
  id               String @id @default(cuid())
  tier             Int
  enchantmentLevel Int    @default(0)
  baseReturnRate   Float
  focusReturnRate  Float
  cityBonusRate    Float  @default(0)

  @@unique([tier, enchantmentLevel])
  @@index([tier])
}

// ══════════════════════════════════════════════════════════════
// MARKET DATA
// ══════════════════════════════════════════════════════════════

enum PriceConfidence {
  HIGH
  MEDIUM
  LOW
  ESTIMATED
  MANUAL
}

model MarketPrice {
  id               String   @id @default(cuid())
  itemId           String
  locationId       String
  quality          Int      @default(1)

  sellPriceMin     Int      @default(0)
  sellPriceMinDate DateTime?
  sellPriceMax     Int      @default(0)
  sellPriceMaxDate DateTime?
  
  buyPriceMin      Int      @default(0)
  buyPriceMinDate  DateTime?
  buyPriceMax      Int      @default(0)
  buyPriceMaxDate  DateTime?

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  updatedAt DateTime

  @@unique([itemId, locationId, quality])
  @@index([itemId])
  @@index([locationId])
  @@index([itemId, locationId])
  @@index([updatedAt])
}

model ResolvedPrice {
  id           String          @id @default(cuid())
  itemId       String
  locationId   String
  quality      Int             @default(1)
  
  sellPrice    Int             @default(0)
  buyPrice     Int             @default(0)
  
  confidence   PriceConfidence @default(LOW)
  source       String?         // e.g. "live", "history_median", "cross_city"
  
  updatedAt    DateTime

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([itemId, locationId, quality])
  @@index([itemId, locationId, quality])
  
  @@index([updatedAt])
}

model MarketPriceHistory {
  id           String   @id @default(cuid())
  itemId       String
  locationId   String
  quality      Int      @default(1)
  
  sellPriceMin Int
  buyPriceMax  Int
  
  timestamp    DateTime @default(now())

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, locationId, quality])
  @@index([itemId, locationId, quality, timestamp])
  @@index([timestamp])
}

// ══════════════════════════════════════════════════════════════
// IMPORT / ADMIN
// ══════════════════════════════════════════════════════════════

model ImportJob {
  id            String       @id @default(cuid())
  type          ImportType
  status        ImportStatus @default(PENDING)

  triggeredById String?
  triggeredBy   User?        @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?

  itemsProcessed Int @default(0)
  itemsCreated   Int @default(0)
  itemsUpdated   Int @default(0)
  itemsSkipped   Int @default(0)
  itemsFailed    Int @default(0)

  sourceCommit String?
  sourceUrl    String?

  errorMessage String?   @db.Text
  logs         ImportLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([triggeredById])
}

model MarketSyncJob {
  id            String       @id @default(cuid())
  type          MarketSyncType
  status        ImportStatus @default(PENDING)

  triggeredById String?
  triggeredBy   User?        @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?

  itemsRequested Int @default(0)
  itemsProcessed Int @default(0)
  itemsUpdated   Int @default(0)
  itemsFailed    Int @default(0)

  errorMessage String?   @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model ImportLog {
  id      String   @id @default(cuid())
  jobId   String
  level   LogLevel @default(INFO)
  message String   @db.Text
  context Json?

  job ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([level])
  @@index([createdAt])
}

model AuditLog {
  id         String  @id @default(cuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     String
  targetType String?
  targetId   String?

  before    Json?
  after     Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════
// SYSTEM CONFIG
// ══════════════════════════════════════════════════════════════

model SystemConfig {
  key         String  @id
  value       Json
  description String?

  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ══════════════════════════════════════════════════════════════
// SCHEDULER
// ══════════════════════════════════════════════════════════════

model JobSchedule {
  id          String   @id @default(cuid())
  name        String   @unique // Internal ID like "market_full_sync"
  label       String   // Human readable name like "Market Full Sync"
  cron        String   // Cron expression
  enabled     Boolean  @default(true)
  
  target      String   // "albion-import" or "albion-market"
  options     Json?    // Specific options for the job (e.g. { "type": "FULL" })
  
  lastRunAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
}

// ══════════════════════════════════════════════════════════════
// SPELLS
// ══════════════════════════════════════════════════════════════

model Spell {
  id       String  @id // uniqueName from spells.json
  icon     String? // @uisprite
  category String? // @category (damage, crowdcontrol, buff...)
  uiType   String? // @uitype (buff, debuff, damage...)
  spellKind String  @default("active") // "active" | "passive" | "toggle"

  cooldown        Float? // @recastdelay
  energyCost      Float? // @energyusage
  castTime        Float? // @castingtime
  channelDuration Float? // @channelduration
  range           Float? // @castrange

  // Localization keys from source (resolve via localization.json)
  nameLocaTag        String? // @namelocatag
  descriptionLocaTag String? // @descriptionlocatag

  // Full source JSON preserved for future use
  rawData Json

  localizations SpellLocalization[]
  itemSpells    ItemSpell[]
  buildSpells   BuildSpell[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spellKind])
  @@index([category])
}

model SpellLocalization {
  id          String  @id @default(cuid())
  spellId     String
  locale      String
  name        String
  description String? @db.Text

  spell Spell @relation(fields: [spellId], references: [id], onDelete: Cascade)

  @@unique([spellId, locale])
  @@index([locale])
}

// Junction: which spells are available on each item (from craftingspelllist)
model ItemSpell {
  id         String @id @default(cuid())
  itemId     String
  spellId    String
  slotNumber Int?   // null = passive, 1 = Q, 2 = W, 3 = E
  tag        String? // alternative choice identifier (A, B, C...)

  item  Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  spell Spell @relation(fields: [spellId], references: [id], onDelete: Cascade)

  @@unique([itemId, spellId])
  @@index([itemId])
  @@index([spellId])
  @@index([slotNumber])
}

// ══════════════════════════════════════════════════════════════
// BUILDS
// ══════════════════════════════════════════════════════════════

// Build = snapshot d'un équipement complet + sélection de spells
model Build {
  id          String          @id @default(cuid())
  shareCode   String          @unique // ~10 chars, base64url — URL de partage
  title       String
  description String?         @db.Text
  gameMode    String?         // "ZvZ", "Solo PvP", "Ganking", "HCE"...
  visibility  BuildVisibility @default(PRIVATE)
  userId      String?
  primaryContentType BuildContentType?
  contentTypes       BuildContentType[] @default([])
  roles              BuildRole[]        @default([])
  groupScales        BuildGroupScale[]  @default([])
  playstyles         BuildPlaystyle[]   @default([])
  difficulty         BuildDifficulty?
  budget             BuildBudget?
  weaponCategory     String?
  weaponSubcategory  String?

  // Équipement stocké en JSON (itemIds). Pas de FK pour éviter
  // la cascade de relations sur Item + supporter les items obsolètes.
  equipment Json? // { weapon?, offhand?, helmet?, armor?, shoes?, cape?, bag?, food?, potion?, mount? }

  spells      BuildSpell[]
  collections BuildCollectionItem[]

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([shareCode])
  @@index([visibility, gameMode])
  @@index([visibility, primaryContentType])
  @@index([weaponSubcategory])
  @@index([createdAt])
}

// Spell sélectionné par slot dans un build
model BuildSpell {
  id      String @id @default(cuid())
  buildId String
  spellId String
  slotKey String // "Q", "W", "E", "P1", "P2" — identifiant de slot

  build Build @relation(fields: [buildId], references: [id], onDelete: Cascade)
  spell Spell @relation(fields: [spellId], references: [id])

  @@unique([buildId, slotKey])
  @@index([buildId])
}

// Collection de builds (ex: "ZvZ Tank", "Ganking") — nécessite un compte
model BuildCollection {
  id          String          @id @default(cuid())
  shareCode   String          @unique
  title       String
  description String?         @db.Text
  visibility  BuildVisibility @default(PRIVATE)
  userId      String

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items BuildCollectionItem[]

  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([shareCode])
  @@index([visibility])
}

model BuildCollectionItem {
  id           String @id @default(cuid())
  collectionId String
  buildId      String
  sortOrder    Int    @default(0)
  note         String?

  collection BuildCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  build      Build           @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([collectionId, buildId])
  @@index([collectionId])
  @@index([buildId])
}

// ══════════════════════════════════════════════════════════════
// ISLANDS & FARMING
// ══════════════════════════════════════════════════════════════

model Island {
  id         String     @id @default(cuid())
  userId     String
  name       String
  type       IslandType @default(PERSONAL)
  locationId String
  level      Int        @default(1)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id])
  buildings IslandBuilding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([locationId])
}

model IslandBuilding {
  id           String    @id @default(cuid())
  islandId     String
  level        Int       @default(1)
  
  nutrition    Float?    // For crafting/refining buildings (0-100)
  metadata     Json?     // Specific data (happiness, furniture, etc.)

  buildingId    String?
  building      CraftingStation? @relation(fields: [buildingId], references: [id])

  island   Island    @relation(fields: [islandId], references: [id], onDelete: Cascade)
  resources BuildingResource[]
  laborers  Laborer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([islandId])
}

model BuildingResource {
  id               String    @id @default(cuid())
  buildingId       String
  itemId           String
  
  count            Int       @default(1)
  plantedAt        DateTime?
  isFocusUsed      Boolean   @default(false)
  
  building         IslandBuilding @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  item             Item           @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([itemId])
}

model Laborer {
  id         String  @id @default(cuid())
  buildingId String
  type       String  // uniqueName of the laborer item
  level      Int     @default(1)
  happiness  Float   @default(0)
  isWorking  Boolean @default(false)
  returnAt   DateTime?

  building IslandBuilding @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
}

model LootTable {
  id           String          @id // e.g. "T1_CARROT_LOOT"
  name         String          @unique
  listType     String?         // from `@listtype` attribute
  rawData      Json            // Complete original nested raw JSON from loot.json
  
  items               LootTableItem[] @relation("LootTableItems")
  referencedInItems   LootTableItem[] @relation("ReferencedInItems")
  
  harvestItems Item[]          @relation("HarvestLootList")
  productItems Item[]          @relation("ProductLootList")
  
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model LootTableItem {
  id                String    @id @default(cuid())
  lootTableId       String
  
  // Either an item uniqueName...
  itemUniqueName    String?
  itemId            String?   // Links to the Item model if the item exists in the DB
  
  // ...or a reference to another loot table
  referencedLootTableId String?
  
  chance            Float     @default(1.0)  // Defaults to 1.0 if not specified
  amount            String    @default("1")    // e.g. "3-6", "1", "25-74"
  weight            Int?                     // For OR/AND blocks that use weight instead of chance
  parentType        String    @default("DIRECT") // e.g. "DIRECT", "OR", "AND"
  useBlackMarket    Boolean   @default(false)
  
  lootTable         LootTable  @relation("LootTableItems", fields: [lootTableId], references: [id], onDelete: Cascade)
  item              Item?      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  referencedLootTable LootTable? @relation("ReferencedInItems", fields: [referencedLootTableId], references: [id], onDelete: SetNull)

  @@index([lootTableId])
  @@index([itemId])
  @@index([referencedLootTableId])
}

